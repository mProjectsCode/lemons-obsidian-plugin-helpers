{
	"name": "@lemons_dev/lemons-obsidian-plugin-automation",
	"version": "0.0.1",
	"description": "Shared repository automation scripts for Lemons Obsidian plugins",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mProjectsCode/lemons-obsidian-plugin-helpers.git",
		"directory": "packages/repo-automation"
	},
	"files": [
		"bin",
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/src/index.d.mts",
			"import": "./dist/src/index.mjs"
		},
		"./release": {
			"types": "./dist/src/release.d.mts",
			"import": "./dist/src/release.mjs"
		}
	},
	"types": "./dist/src/index.d.mts",
	"bin": {
		"lemons-automation": "bin/lemons-automation.js"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "bun run clean && tsdown --config tsdown.config.ts",
		"prepack": "bun run build",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "bun test src",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint --fix src/**/*.ts"
	},
	"dependencies": {
		"@lemons_dev/parsinom": "^0.1.0",
		"moment": "^2.30.1",
		"string-argv": "^0.3.2"
	},
	"peerDependencies": {
		"vite": "^8.0.0"
	}
}
