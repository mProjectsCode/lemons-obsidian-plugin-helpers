{
	"name": "lemons-obsidian-plugin-helpers",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"files": [
		"bin",
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/packages/helpers/src/index.d.mts",
			"import": "./dist/packages/helpers/src/index.mjs"
		},
		"./repo-automation": {
			"types": "./dist/packages/repo-automation/src/index.d.mts",
			"import": "./dist/packages/repo-automation/src/index.mjs"
		},
		"./release": {
			"types": "./dist/packages/repo-automation/src/release.d.mts",
			"import": "./dist/packages/repo-automation/src/release.mjs"
		}
	},
	"types": "./dist/packages/helpers/src/index.d.mts",
	"bin": {
		"lemons-helpers": "./bin/lemons-helpers.js"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "bun run clean && tsdown --config tsdown.config.ts",
		"prepack": "bun run build",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "bun run format:check && bun run typecheck && bun run lint && bun run test"
	},
	"dependencies": {
		"@lemons_dev/parsinom": "^0.1.0",
		"moment": "^2.30.1",
		"string-argv": "^0.3.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/bun": "^1.3.12",
		"eslint": "^9.39.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-only-warn": "^1.2.1",
		"prettier": "^3.8.3",
		"tsdown": "^0.21.9",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8"
	}
}
