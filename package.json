{
	"name": "lemons-obsidian-plugin-monorepo",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/helpers",
		"packages/repo-automation"
	],
	"scripts": {
		"clean": "bun run clean:helpers && bun run clean:repo-automation",
		"clean:helpers": "cd packages/helpers && bun run clean",
		"clean:repo-automation": "cd packages/repo-automation && bun run clean",
		"build": "bun run build:helpers && bun run build:repo-automation",
		"build:helpers": "cd packages/helpers && bun run build",
		"build:repo-automation": "cd packages/repo-automation && bun run build",
		"release:package": "bun run monorepoRelease.ts",
		"typecheck": "bun run typecheck:helpers && bun run typecheck:repo-automation",
		"typecheck:helpers": "cd packages/helpers && bun run typecheck",
		"typecheck:repo-automation": "cd packages/repo-automation && bun run typecheck",
		"test": "bun run test:helpers && bun run test:repo-automation",
		"test:helpers": "cd packages/helpers && bun run test",
		"test:repo-automation": "cd packages/repo-automation && bun run test",
		"test:watch": "bun test --watch",
		"lint": "bun run lint:helpers && bun run lint:repo-automation",
		"lint:helpers": "cd packages/helpers && bun run lint",
		"lint:repo-automation": "cd packages/repo-automation && bun run lint",
		"lint:fix": "bun run lint:fix:helpers && bun run lint:fix:repo-automation",
		"lint:fix:helpers": "cd packages/helpers && bun run lint:fix",
		"lint:fix:repo-automation": "cd packages/repo-automation && bun run lint:fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "bun run format:check && bun run typecheck && bun run lint && bun run test"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/bun": "^1.3.13",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-only-warn": "^1.2.1",
		"prettier": "^3.8.3",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.9"
	}
}
